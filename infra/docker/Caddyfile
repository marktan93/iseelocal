{
    on_demand_tls {
        ask http://tunnel-sshd:8081/api/tls-ask
    }
}

{$ISEELOCAL_BASE_DOMAIN}, http://{$ISEELOCAL_BASE_DOMAIN} {
    encode zstd gzip
    reverse_proxy tunnel-sshd:8081
}

api.{$ISEELOCAL_BASE_DOMAIN}, http://api.{$ISEELOCAL_BASE_DOMAIN} {
    encode zstd gzip
    reverse_proxy tunnel-sshd:8081
}

http://*.{$ISEELOCAL_BASE_DOMAIN} {
    encode zstd gzip
    reverse_proxy tunnel-sshd:8080
}

https:// {
    tls {
        on_demand
    }
    @route host *.{$ISEELOCAL_BASE_DOMAIN}
    handle @route {
        encode zstd gzip
        reverse_proxy tunnel-sshd:8080
    }
    respond "not found" 404
}

http:// {
    encode zstd gzip
    reverse_proxy tunnel-sshd:8081
}
