{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iseelocal",
  "version": "0.1.0",
  "identifier": "com.iseelocal.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "iseelocal",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.svg"]
  }
}
